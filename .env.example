# EmailJS (contact form)
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Resend (premium email)
# Get your key at https://resend.com/api-keys
# Free tier: 3,000 emails/month
# For production: verify your domain in Resend dashboard (add SPF/DKIM/DMARC records)
RESEND_API_KEY=
FROM_EMAIL="Meteoric <onboarding@resend.dev>"
ADMIN_EMAIL=

# Cal.com (booking integration)
CALCOM_API_KEY=

# Google Gemini AI (lead scoring, content generation)
# Get a free API key at https://aistudio.google.com/apikey
GOOGLE_API=

# Cron job secret (protects /api/cron/* endpoints)
CRON_SECRET=

# AI provider: "google" (default) or "openai"
AI_PROVIDER=google

# AI model (default: gemini-1.5-flash — cheapest)
AI_MODEL=gemini-1.5-flash

# Site URL (used for preview links, emails, WhatsApp)
NEXT_PUBLIC_SITE_URL=http://localhost:3000


